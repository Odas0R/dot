#!/usr/bin/env node

import { readFile } from "node:fs/promises";
import { spawn } from "node:child_process";
import { join } from "node:path";
import process from "node:process";

const DEP_TYPES = [
  "dependencies",
  "devDependencies",
  "optionalDependencies",
  "peerDependencies",
];

const TYPE_LABEL = {
  dependencies: "dep",
  devDependencies: "dev",
  optionalDependencies: "opt",
  peerDependencies: "peer",
};

const LINK_TARGETS = new Set(["latest", "wanted", "patch", "minor", "major"]);

const colorEnabled = process.stdout.isTTY && !process.env.NO_COLOR;
const c = {
  bold: (s) => (colorEnabled ? `\x1b[1m${s}\x1b[0m` : s),
  dim: (s) => (colorEnabled ? `\x1b[2m${s}\x1b[0m` : s),
  green: (s) => (colorEnabled ? `\x1b[32m${s}\x1b[0m` : s),
  yellow: (s) => (colorEnabled ? `\x1b[33m${s}\x1b[0m` : s),
  red: (s) => (colorEnabled ? `\x1b[31m${s}\x1b[0m` : s),
  magenta: (s) => (colorEnabled ? `\x1b[35m${s}\x1b[0m` : s),
  cyan: (s) => (colorEnabled ? `\x1b[36m${s}\x1b[0m` : s),
};

function usage() {
  console.log(`Usage: npm-check-updates [options] [package-filter...]

Minimal, dependency-free npm update checker. It extends \`npm outdated\` by showing
the highest stable patch, minor, and major targets.

Options:
  --json                 Print JSON
  --links[=target]       Print npm/GitHub changelog/release links
                         target: latest, wanted, patch, minor, major (default: latest)
  --target <target>      Link target when using --links
  --verbose              Include npm range/wanted/type columns
  --concurrency <n>      npm registry requests in parallel (default: 6)
  -h, --help             Show help

Examples:
  npm-check-updates
  npm-check-updates react @types
  npm-check-updates --links
  npm-check-updates --links=major hono
  npm-check-updates --json`);
}

function parseArgs(argv) {
  const args = {
    json: false,
    concurrency: 6,
    filters: [],
    links: false,
    linkTarget: "latest",
    verbose: false,
  };

  for (let i = 0; i < argv.length; i++) {
    const arg = argv[i];

    if (arg === "-h" || arg === "--help") {
      usage();
      process.exit(0);
    }

    if (arg === "--json") {
      args.json = true;
      continue;
    }

    if (arg === "--links") {
      args.links = true;
      continue;
    }

    if (arg === "--verbose" || arg === "-v") {
      args.verbose = true;
      continue;
    }

    if (arg.startsWith("--links=")) {
      args.links = true;
      args.linkTarget = validateLinkTarget(arg.slice("--links=".length));
      continue;
    }

    if (arg === "--target" || arg === "--link-target") {
      args.linkTarget = validateLinkTarget(argv[++i]);
      continue;
    }

    if (arg === "--concurrency") {
      const value = Number(argv[++i]);
      if (!Number.isInteger(value) || value < 1) {
        throw new Error("--concurrency must be a positive integer");
      }
      args.concurrency = value;
      continue;
    }

    args.filters.push(arg);
  }

  return args;
}

function validateLinkTarget(target) {
  if (!LINK_TARGETS.has(target)) {
    throw new Error(`link target must be one of: ${Array.from(LINK_TARGETS).join(", ")}`);
  }
  return target;
}

function runNpm(npmArgs) {
  return new Promise((resolve, reject) => {
    const child = spawn("npm", npmArgs, {
      cwd: process.cwd(),
      stdio: ["ignore", "pipe", "pipe"],
    });

    let stdout = "";
    let stderr = "";

    child.stdout.setEncoding("utf8");
    child.stderr.setEncoding("utf8");
    child.stdout.on("data", (chunk) => (stdout += chunk));
    child.stderr.on("data", (chunk) => (stderr += chunk));
    child.on("error", reject);
    child.on("close", (code) => {
      const result = { code, stdout, stderr };
      if (code === 0) resolve(result);
      else {
        const error = new Error(stderr.trim() || `npm ${npmArgs.join(" ")} failed`);
        Object.assign(error, result);
        reject(error);
      }
    });
  });
}

async function readPackageJson() {
  try {
    return JSON.parse(await readFile("package.json", "utf8"));
  } catch (error) {
    throw new Error(`Could not read package.json in ${process.cwd()}: ${error.message}`);
  }
}

async function npmOutdated() {
  try {
    const { stdout } = await runNpm(["outdated", "--json", "--long"]);
    return stdout.trim() ? JSON.parse(stdout) : {};
  } catch (error) {
    // npm exits with 1 when outdated dependencies exist. The JSON is still useful.
    if (error.stdout?.trim()) return JSON.parse(error.stdout);
    throw error;
  }
}

async function npmVersions(name) {
  const { stdout } = await runNpm(["view", name, "versions", "--json"]);
  const parsed = JSON.parse(stdout || "[]");
  return Array.isArray(parsed) ? parsed : [parsed];
}

async function npmPackageMeta(name, version) {
  const spec = version ? `${name}@${version}` : name;
  const { stdout } = await runNpm([
    "view",
    spec,
    "repository",
    "homepage",
    "bugs",
    "gitHead",
    "--json",
  ]);
  return JSON.parse(stdout || "{}");
}

function parseVersion(version) {
  if (typeof version !== "string") return null;
  const match = version.trim().match(/^v?(\d+)\.(\d+)\.(\d+)(?:\+[-0-9A-Za-z.]+)?$/);
  if (!match) return null;
  return {
    raw: version.replace(/^v/, ""),
    major: Number(match[1]),
    minor: Number(match[2]),
    patch: Number(match[3]),
  };
}

function compareVersions(a, b) {
  return a.major - b.major || a.minor - b.minor || a.patch - b.patch;
}

function isGreater(a, b) {
  return compareVersions(a, b) > 0;
}

function extractVersion(spec) {
  if (typeof spec !== "string") return null;
  const match = spec.match(/\d+\.\d+\.\d+/);
  return match ? parseVersion(match[0]) : null;
}

function pickHighest(versions, predicate) {
  return versions.filter(predicate).sort(compareVersions).at(-1)?.raw ?? null;
}

function classifyTargets(availableVersions, currentVersion) {
  const current = parseVersion(currentVersion);
  if (!current) {
    return { patch: null, minor: null, major: null };
  }

  const versions = availableVersions
    .map(parseVersion)
    .filter(Boolean)
    .filter((version) => isGreater(version, current));

  return {
    patch: pickHighest(
      versions,
      (version) => version.major === current.major && version.minor === current.minor,
    ),
    minor: pickHighest(
      versions,
      (version) => version.major === current.major && version.minor > current.minor,
    ),
    major: pickHighest(versions, (version) => version.major > current.major),
  };
}

function dependencyMap(pkg) {
  const result = new Map();

  for (const type of DEP_TYPES) {
    for (const [name, spec] of Object.entries(pkg?.[type] ?? {})) {
      result.set(name, { name, spec, type });
    }
  }

  return result;
}

function normalizeOutdated(outdated, filters) {
  return Object.entries(outdated)
    .filter(([name]) => filters.length === 0 || filters.some((filter) => name.includes(filter)))
    .flatMap(([name, value]) => {
      const infos = Array.isArray(value) ? value : [value];
      return infos.map((info, index) => ({ name, info: info ?? {}, index }));
    })
    .sort((a, b) => {
      const aLocation = manifestLocation(a.info);
      const bLocation = manifestLocation(b.info);
      const byLocation = aLocation.localeCompare(bLocation);
      if (byLocation) return byLocation;

      const byName = a.name.localeCompare(b.name);
      return byName || a.index - b.index;
    });
}

function manifestLocation(info) {
  return typeof info.dependedByLocation === "string" ? info.dependedByLocation : "";
}

async function dependencyForInfo(name, info, rootPkg, manifestCache) {
  const location = manifestLocation(info);
  const pkg = await readManifest(location, rootPkg, manifestCache);
  return dependencyMap(pkg).get(name);
}

async function readManifest(location, rootPkg, manifestCache) {
  if (!location) return rootPkg;

  if (!manifestCache.has(location)) {
    manifestCache.set(
      location,
      readFile(join(location, "package.json"), "utf8")
        .then(JSON.parse)
        .catch(() => null),
    );
  }

  return manifestCache.get(location);
}

function packageCounts(rows) {
  const result = new Map();
  for (const row of rows) result.set(row.name, (result.get(row.name) ?? 0) + 1);
  return result;
}

function workspaceText(row) {
  if (typeof row.dependedBy === "string") return row.dependedBy || ".";
  return row.dependent ?? "-";
}

async function mapLimit(items, limit, mapper) {
  const results = new Array(items.length);
  let index = 0;

  async function worker() {
    while (index < items.length) {
      const currentIndex = index++;
      results[currentIndex] = await mapper(items[currentIndex], currentIndex);
    }
  }

  await Promise.all(
    Array.from({ length: Math.min(limit, items.length) }, () => worker()),
  );

  return results;
}

function visibleLength(value) {
  return String(value).replace(/\x1b\[[0-9;]*m/g, "").length;
}

function pad(value, width) {
  const text = String(value);
  return text + " ".repeat(Math.max(0, width - visibleLength(text)));
}

function targetText(value, color) {
  if (!value) return c.dim("-");
  return color(value);
}

function printTable(rows, { verbose = false } = {}) {
  if (rows.length === 0) {
    console.log(c.green("All dependencies are current."));
    return;
  }

  const counts = packageCounts(rows);
  const workspaces = new Set(
    rows
      .map((row) => (typeof row.dependedBy === "string" ? row.dependedBy : null))
      .filter((workspace) => workspace !== null),
  );
  const showWorkspace =
    workspaces.size > 1 ||
    Array.from(workspaces).some(Boolean) ||
    rows.some((row) => counts.get(row.name) > 1);
  const table = rows.map((row) => ({
    package: row.name,
    workspace: workspaceText(row),
    type: TYPE_LABEL[row.type] ?? row.type ?? "-",
    range: row.spec ?? "-",
    current: row.current ?? "-",
    wanted: row.wanted ?? "-",
    patch: row.targets.patch ?? "-",
    minor: row.targets.minor ?? "-",
    major: row.targets.major ?? "-",
  }));

  const workspaceHeader = showWorkspace ? { workspace: "Workspace" } : {};
  const headers = verbose
    ? {
        package: "Package",
        ...workspaceHeader,
        type: "Type",
        range: "Range",
        current: "Current",
        wanted: "Wanted",
        patch: "Patch",
        minor: "Minor",
        major: "Major",
      }
    : {
        package: "Package",
        ...workspaceHeader,
        current: "Current",
        patch: "Patch",
        minor: "Minor",
        major: "Major",
      };

  const columns = Object.keys(headers);
  const widths = Object.fromEntries(
    columns.map((column) => [
      column,
      Math.max(
        visibleLength(headers[column]),
        ...table.map((row) => visibleLength(row[column])),
      ),
    ]),
  );

  console.log(columns.map((column) => c.bold(pad(headers[column], widths[column]))).join("  "));
  console.log(columns.map((column) => c.dim("-".repeat(widths[column]))).join("  "));

  for (const row of rows) {
    const rendered = {
      package: row.name,
      workspace: c.dim(workspaceText(row)),
      type: c.dim(TYPE_LABEL[row.type] ?? row.type ?? "-"),
      range: c.dim(row.spec ?? "-"),
      current: row.current ?? c.dim("-"),
      wanted: row.wanted && row.wanted !== row.current ? c.cyan(row.wanted) : c.dim(row.wanted ?? "-"),
      patch: targetText(row.targets.patch, c.green),
      minor: targetText(row.targets.minor, c.yellow),
      major: targetText(row.targets.major, c.red),
    };

    console.log(columns.map((column) => pad(rendered[column], widths[column])).join("  "));
  }

  const count =
    rows.length === 1
      ? `1 ${showWorkspace ? "dependency entry" : "dependency"}`
      : `${rows.length} ${showWorkspace ? "dependency entries" : "dependencies"}`;
  console.log(c.dim(`\n${count} with newer versions.`));
}

function cleanUrl(url) {
  return typeof url === "string" && url.trim() ? url.trim() : null;
}

function repositoryUrl(repository) {
  if (!repository) return null;
  return cleanUrl(typeof repository === "string" ? repository : repository.url);
}

function bugUrl(bugs) {
  if (!bugs) return null;
  return cleanUrl(typeof bugs === "string" ? bugs : bugs.url);
}

function githubRepoUrl(url) {
  if (!url) return null;

  const normalized = url
    .replace(/^git\+/, "")
    .replace(/^git:\/\//, "https://")
    .replace(/^ssh:\/\/git@github\.com\//, "https://github.com/")
    .replace(/^git@github\.com:/, "https://github.com/");

  const match = normalized.match(/github\.com[/:]([^/\s]+)\/([^/#?\s]+?)(?:\.git)?(?:[/#?]|$)/i);
  if (!match) return null;

  return `https://github.com/${match[1]}/${match[2].replace(/\.git$/, "")}`;
}

function npmPackageUrl(name, version) {
  return `https://www.npmjs.com/package/${name}${version ? `/v/${version}` : ""}`;
}

function unique(values) {
  return Array.from(new Set(values.filter(Boolean)));
}

function unscopedName(name) {
  return name.split("/").at(-1);
}

function releaseTagCandidates(name, version) {
  const shortName = unscopedName(name);
  return unique([
    `v${version}`,
    version,
    `${shortName}@${version}`,
    `${name}@${version}`,
  ]);
}

function githubTagUrl(repo, tag) {
  return `${repo}/releases/tag/${encodeURIComponent(tag)}`;
}

function githubCompareUrl(repo, from, to) {
  return `${repo}/compare/${encodeURIComponent(from)}...${encodeURIComponent(to)}`;
}

function linkVersion(row, target) {
  if (target === "wanted") return row.wanted;
  if (target === "latest") return row.latest;
  return row.targets[target];
}

function buildLinks(row, meta, target, version) {
  const repoUrl = repositoryUrl(meta.repository);
  const github = githubRepoUrl(repoUrl ?? meta.homepage ?? bugUrl(meta.bugs));
  const links = {
    target,
    version,
    npm: npmPackageUrl(row.name, version),
    homepage: cleanUrl(meta.homepage),
    repository: github ?? repoUrl,
    bugs: bugUrl(meta.bugs),
    commit: null,
    releases: [],
    compares: [],
    changelogs: [],
  };

  if (!github) return links;

  const targetTags = releaseTagCandidates(row.name, version);
  links.releases = targetTags.map((tag) => githubTagUrl(github, tag));

  if (row.current) {
    const currentTags = releaseTagCandidates(row.name, row.current);
    links.compares = unique(
      targetTags.map((targetTag, index) => {
        const currentTag = currentTags[index];
        return currentTag ? githubCompareUrl(github, currentTag, targetTag) : null;
      }),
    );
  }

  const directory =
    typeof meta.repository === "object" ? cleanUrl(meta.repository.directory)?.replace(/^\/+|\/+$/g, "") : null;

  links.changelogs = unique([
    `${github}/releases`,
    directory ? `${github}/blob/HEAD/${directory}/CHANGELOG.md` : null,
    directory ? `${github}/blob/HEAD/${directory}/CHANGELOG` : null,
    `${github}/blob/HEAD/CHANGELOG.md`,
    `${github}/blob/HEAD/CHANGELOG`,
    `${github}/blob/HEAD/Changes.md`,
  ]);

  if (meta.gitHead) {
    links.commit = `${github}/commit/${meta.gitHead}`;
  }

  return links;
}

async function attachLinks(row, target) {
  const version = linkVersion(row, target);
  if (!version || version === row.current) return row;

  try {
    const meta = await npmPackageMeta(row.name, version);
    return { ...row, links: buildLinks(row, meta, target, version) };
  } catch (error) {
    return {
      ...row,
      links: {
        target,
        version,
        npm: npmPackageUrl(row.name, version),
        error: error.message,
      },
    };
  }
}

function printLinkList(label, values, limit = 4) {
  const list = unique(values ?? []).slice(0, limit);
  if (list.length === 0) return;

  console.log(`  ${c.dim(`${label}:`)} ${list[0]}`);
  for (const value of list.slice(1)) {
    console.log(`  ${" ".repeat(label.length + 1)} ${value}`);
  }
}

function printLinks(rows, target) {
  const linked = rows.filter((row) => row.links);
  if (linked.length === 0) return;

  console.log(`\n${c.bold(`Links (${target})`)}`);
  for (const row of linked) {
    const links = row.links;
    console.log(`${c.bold(`${row.name}@${links.version}`)} ${c.dim(`from ${row.current}`)}`);
    printLinkList("npm", [links.npm]);
    printLinkList("release", links.releases, 4);
    printLinkList("compare", links.compares, 4);
    printLinkList("changelog", links.changelogs, 4);
    printLinkList("commit", [links.commit]);
    printLinkList("homepage", [links.homepage]);
    printLinkList("repo", [links.repository]);
    if (links.error) console.log(`  ${c.dim("error:")} ${links.error}`);
  }
}

async function main() {
  const args = parseArgs(process.argv.slice(2));
  const pkg = await readPackageJson();
  const outdated = await npmOutdated();
  const manifestCache = new Map();
  const versionCache = new Map();
  const outdatedEntries = normalizeOutdated(outdated, args.filters);

  let rows = await mapLimit(outdatedEntries, args.concurrency, async ({ name, info }) => {
    const dep = await dependencyForInfo(name, info, pkg, manifestCache);
    const current = parseVersion(info.current)?.raw ?? info.current ?? extractVersion(dep?.spec)?.raw;

    if (!versionCache.has(name)) versionCache.set(name, npmVersions(name));
    const versions = await versionCache.get(name);
    const targets = classifyTargets(versions, current);

    return {
      name,
      type: info.type ?? dep?.type,
      spec: dep?.spec,
      current,
      wanted: info.wanted,
      latest: info.latest,
      dependent: info.dependent,
      dependedBy: info.dependedByLocation,
      location: info.location,
      targets,
    };
  });

  if (args.links) {
    rows = await mapLimit(rows, args.concurrency, (row) => attachLinks(row, args.linkTarget));
  }

  if (args.json) {
    console.log(JSON.stringify(rows, null, 2));
    return;
  }

  printTable(rows, { verbose: args.verbose });
  if (args.links) printLinks(rows, args.linkTarget);
}

main().catch((error) => {
  console.error(`npm-check-updates: ${error.message}`);
  process.exit(1);
});
