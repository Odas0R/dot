#!/usr/bin/env node

import fs from "node:fs";
import os from "node:os";
import path from "node:path";
import process from "node:process";
import { spawnSync } from "node:child_process";

const HELP = `
wt - small git worktree helper

Usage:
  wt list
  wt new <branch> [base] [--path <path>] [--env]
  wt add <branch> [--path <path>] [--env]
  wt tmp [name] [--env] [--fork|--no-fork]
  wt promote <branch>
  wt pr [base]
  wt path [branch]
  wt cd [branch]
  wt rm [branch] [--force]
  wt prune [git-prune-options]

Examples:
  wt new feature/login
  wt new feature/login main
  wt add existing-branch
  wt tmp branch-out-title --env
  wt promote agent/login
  wt pr
  wt cd feature/login
  wt rm feature/login

Default persistent worktree location:
  ../<repo>.worktrees/<branch-slug>

Default temporary worktree location:
  $TMPDIR/wt/<repo>-<name-or-branch-or-head>-XXXXXX

Environment files:
  Pass --env to copy .env files from the current worktree.

Workspace forking:
  Pass --fork to copy the current tracked diff plus untracked non-ignored
  files into the new temporary worktree. When wt tmp is run from an existing
  temporary wt worktree, this happens by default so nested sessions continue
  from the current workspace. Pass --no-fork to force a clean checkout.

Temporary workflow:
  wt tmp [name] remembers the source branch. The optional name labels the
  temporary path but does not create a branch. After committing in the temp
  worktree, use wt promote <branch> to attach it to a branch, then wt pr to
  push it and open a pull request against the source branch.
`;

function die(message, code = 1) {
  console.error(`wt: ${message}`);
  process.exit(code);
}

function expandHome(value) {
  if (!value) return value;
  if (value === "~") return os.homedir();
  if (value.startsWith("~/")) return path.join(os.homedir(), value.slice(2));
  return value;
}

function git(args, options = {}) {
  const result = spawnSync("git", args, {
    cwd: options.cwd ?? process.cwd(),
    encoding: options.encoding ?? "utf8",
    input: options.input,
    stdio: options.stdio ?? [options.input === undefined ? "ignore" : "pipe", "pipe", "pipe"],
  });

  if (result.error) {
    die(`could not run git: ${result.error.message}`);
  }

  if (result.status !== 0 && !options.allowFailure) {
    const stderr = typeof result.stderr === "string" ? result.stderr.trim() : "";
    const stdout = typeof result.stdout === "string" ? result.stdout.trim() : "";
    die(stderr || stdout || `git ${args.join(" ")} failed`);
  }

  return result;
}

function gitOutput(args, options = {}) {
  return git(args, options).stdout.trimEnd();
}

function gitVisible(args, options = {}) {
  const result = spawnSync("git", args, {
    cwd: options.cwd ?? process.cwd(),
    encoding: "utf8",
    stdio: ["inherit", "pipe", "pipe"],
  });

  if (result.error) {
    die(`could not run git: ${result.error.message}`);
  }

  if (result.stdout) process.stderr.write(result.stdout);
  if (result.stderr) process.stderr.write(result.stderr);

  if (result.status !== 0 && !options.allowFailure) {
    die(`git ${args.join(" ")} failed`);
  }

  return result;
}

function commandVisible(command, args, options = {}) {
  const result = spawnSync(command, args, {
    cwd: options.cwd ?? process.cwd(),
    encoding: "utf8",
    stdio: "inherit",
  });

  if (result.error) {
    die(`could not run ${command}: ${result.error.message}`);
  }

  if (result.status !== 0 && !options.allowFailure) {
    die(`${command} ${args.join(" ")} failed`);
  }

  return result;
}

function ensureInsideGitWorktree() {
  const result = git(["rev-parse", "--is-inside-work-tree"], {
    allowFailure: true,
  });

  if (result.status !== 0 || result.stdout.trim() !== "true") {
    die("not inside a git worktree");
  }
}

function parseWorktreeList(output) {
  const worktrees = [];
  let current = null;

  for (const line of output.split(/\r?\n/)) {
    if (line === "") {
      if (current) worktrees.push(current);
      current = null;
      continue;
    }

    const firstSpace = line.indexOf(" ");
    const key = firstSpace === -1 ? line : line.slice(0, firstSpace);
    const value = firstSpace === -1 ? "" : line.slice(firstSpace + 1);

    if (key === "worktree") {
      if (current) worktrees.push(current);
      current = { path: value };
      continue;
    }

    if (!current) continue;

    if (key === "HEAD") current.head = value;
    if (key === "branch") current.branchRef = value;
    if (key === "detached") current.detached = true;
    if (key === "bare") current.bare = true;
    if (key === "prunable") current.prunable = value || true;
  }

  if (current) worktrees.push(current);

  return worktrees.map((worktree) => ({
    ...worktree,
    branch: friendlyBranch(worktree.branchRef),
  }));
}

function worktrees() {
  ensureInsideGitWorktree();
  return parseWorktreeList(gitOutput(["worktree", "list", "--porcelain"]));
}

function currentBranch(cwd = process.cwd()) {
  return gitOutput(["branch", "--show-current"], {
    cwd,
    allowFailure: true,
  });
}

function friendlyBranch(ref) {
  if (!ref) return null;
  return ref.replace(/^refs\/heads\//, "").replace(/^refs\/remotes\//, "");
}

function shortHead(head) {
  return head ? head.slice(0, 7) : "unknown";
}

function labelFor(worktree) {
  if (worktree.branch) return worktree.branch;
  if (worktree.detached) return `(detached ${shortHead(worktree.head)})`;
  if (worktree.bare) return "(bare)";
  return "(unknown)";
}

function branchSlug(branch) {
  const slug = friendlyBranch(branch)
    .trim()
    .replace(/^[./]+|[./]+$/g, "")
    .replace(/[^A-Za-z0-9._-]+/g, "-")
    .replace(/-+/g, "-");

  if (!slug) die(`could not create a path slug for branch '${branch}'`);
  return slug;
}

function repoInfo() {
  const entries = worktrees();
  if (entries.length === 0) die("git returned no worktrees");

  const mainPath = entries[0].path;
  const repoName = path.basename(mainPath);
  const configuredHome = process.env.WT_HOME;
  const baseDir = configuredHome
    ? path.join(path.resolve(expandHome(configuredHome)), repoName)
    : path.join(path.dirname(mainPath), `${repoName}.worktrees`);

  return { entries, mainPath, repoName, baseDir };
}

function defaultWorktreePath(branch) {
  return path.join(repoInfo().baseDir, branchSlug(branch));
}

function defaultTemporaryWorktreePath(name = null) {
  const parent = path.join(os.tmpdir(), "wt");
  fs.mkdirSync(parent, { recursive: true });

  const branch = currentBranch();
  const head = gitOutput(["rev-parse", "--short", "HEAD"]);
  const label = name || branch || head;

  return fs.mkdtempSync(
    path.join(parent, `${branchSlug(repoInfo().repoName)}-${branchSlug(label)}-`),
  );
}

function worktreeGitDir(cwd = process.cwd()) {
  const gitDir = gitOutput(["rev-parse", "--git-dir"], { cwd });
  return path.isAbsolute(gitDir) ? gitDir : path.resolve(cwd, gitDir);
}

function worktreeMetadataPath(cwd = process.cwd()) {
  return path.join(worktreeGitDir(cwd), "wt-meta.json");
}

function readWorktreeMetadata(cwd = process.cwd()) {
  const file = worktreeMetadataPath(cwd);
  if (!fs.existsSync(file)) return null;

  try {
    return JSON.parse(fs.readFileSync(file, "utf8"));
  } catch (error) {
    die(`could not read worktree metadata ${file}: ${error.message}`);
  }
}

function writeWorktreeMetadata(cwd, metadata) {
  const file = worktreeMetadataPath(cwd);
  fs.writeFileSync(file, `${JSON.stringify(metadata, null, 2)}\n`);
}

function parseOptions(args, definitions = {}) {
  const options = {};
  const rest = [];

  for (let index = 0; index < args.length; index += 1) {
    const arg = args[index];

    if (arg === "--") {
      rest.push(...args.slice(index + 1));
      break;
    }

    if (arg === "-h" || arg === "--help") {
      console.log(HELP.trim());
      process.exit(0);
    }

    if ((arg === "-p" || arg === "--path") && definitions.path) {
      const value = args[index + 1];
      if (!value) die(`${arg} needs a path`);
      options.path = path.resolve(expandHome(value));
      index += 1;
      continue;
    }

    if ((arg === "-f" || arg === "--force") && definitions.force) {
      options.force = true;
      continue;
    }

    if (arg === "--env" && definitions.env) {
      options.copyEnv = true;
      continue;
    }

    if (arg === "--no-env" && definitions.env) {
      options.copyEnv = false;
      continue;
    }

    if (arg === "--fork" && definitions.fork) {
      options.fork = true;
      continue;
    }

    if (arg === "--no-fork" && definitions.fork) {
      options.fork = false;
      continue;
    }

    if (arg.startsWith("-")) die(`unknown option '${arg}'`);
    rest.push(arg);
  }

  return { options, rest };
}

function commandExists(command) {
  const result = spawnSync("bash", ["-lc", `command -v ${command}`], {
    encoding: "utf8",
    stdio: ["ignore", "pipe", "ignore"],
  });

  return result.status === 0;
}

function selectWorktree(entries) {
  if (entries.length === 0) die("no worktrees to select");

  if (!commandExists("fzf")) {
    if (entries.length === 1) return entries[0];
    die("pass a branch name or install fzf for interactive selection");
  }

  const input = entries
    .map((entry) => `${labelFor(entry)}\t${entry.path}`)
    .join("\n");

  const result = spawnSync(
    "fzf",
    ["--prompt=worktree> ", "--delimiter=\t", "--with-nth=1,2"],
    {
      input,
      encoding: "utf8",
      stdio: ["pipe", "pipe", "inherit"],
    },
  );

  if (result.error) die(`could not run fzf: ${result.error.message}`);
  if (result.status !== 0) process.exit(result.status ?? 1);

  const selected = result.stdout.trimEnd();
  const selectedPath = selected.split("\t").at(-1);
  const entry = entries.find((candidate) => candidate.path === selectedPath);

  if (!entry) die("could not read selected worktree");
  return entry;
}

function findWorktree(query, entries) {
  const expandedQuery = expandHome(query);
  const resolvedQuery = path.resolve(expandedQuery);
  const normalizedBranch = friendlyBranch(query);

  const exactMatches = entries.filter((entry) => {
    const entryPath = path.resolve(entry.path);
    const branch = entry.branch ?? "";

    return (
      entry.path === expandedQuery ||
      entryPath === resolvedQuery ||
      branch === normalizedBranch ||
      branchSlug(branch || labelFor(entry)) === normalizedBranch ||
      path.basename(entry.path) === normalizedBranch
    );
  });

  if (exactMatches.length === 1) return exactMatches[0];
  if (exactMatches.length > 1) {
    die(
      `ambiguous worktree '${query}':\n` +
        exactMatches.map((entry) => `  ${labelFor(entry)} -> ${entry.path}`).join("\n"),
    );
  }

  const suffixMatches = entries.filter((entry) =>
    entry.branch?.endsWith(`/${normalizedBranch}`),
  );

  if (suffixMatches.length === 1) return suffixMatches[0];
  if (suffixMatches.length > 1) {
    die(
      `ambiguous worktree '${query}':\n` +
        suffixMatches.map((entry) => `  ${labelFor(entry)} -> ${entry.path}`).join("\n"),
    );
  }

  die(`no worktree found for '${query}'`);
}

function currentWorktree(entries) {
  const currentRoot = gitOutput(["rev-parse", "--show-toplevel"]);
  return entries.find((entry) => path.resolve(entry.path) === path.resolve(currentRoot));
}

function branchExists(branch) {
  return (
    git(["rev-parse", "--verify", "--quiet", `refs/heads/${branch}`], {
      allowFailure: true,
    }).status === 0
  );
}

function defaultTargetBranch(sourceBranch, entries, metadata = null) {
  const sourceMetadataBranch = metadata?.sourceBranch;
  if (sourceMetadataBranch && sourceMetadataBranch !== sourceBranch) {
    return sourceMetadataBranch;
  }

  const remoteHead = gitOutput(
    ["symbolic-ref", "--quiet", "--short", "refs/remotes/origin/HEAD"],
    { allowFailure: true },
  );

  if (remoteHead) {
    const branch = remoteHead.replace(/^[^/]+\//, "");
    if (branch && branch !== sourceBranch) return branch;
  }

  for (const branch of ["main", "master", "trunk", "develop"]) {
    if (branch !== sourceBranch && branchExists(branch)) return branch;
  }

  const mainWorktreeBranch = entries[0]?.branch;
  if (mainWorktreeBranch && mainWorktreeBranch !== sourceBranch) {
    return mainWorktreeBranch;
  }

  die("could not determine target branch; pass one explicitly");
}

function ensureClean(entry, description) {
  const status = gitOutput(["status", "--porcelain"], { cwd: entry.path });
  if (status) {
    die(`${description} worktree has uncommitted changes: ${entry.path}`);
  }
}

function isEnvFileName(name) {
  return name === ".env" || name.startsWith(".env.");
}

function isInsidePath(candidate, parent) {
  const relative = path.relative(parent, candidate);
  return relative === "" || (!relative.startsWith("..") && !path.isAbsolute(relative));
}

function shouldSkipEnvSearchDirectory(name) {
  return name === ".git" || name === "node_modules";
}

function copyEnvFiles(sourceRoot, targetRoot) {
  const resolvedSourceRoot = path.resolve(sourceRoot);
  const resolvedTargetRoot = path.resolve(targetRoot);

  if (resolvedSourceRoot === resolvedTargetRoot) return;
  if (!fs.existsSync(resolvedSourceRoot) || !fs.existsSync(resolvedTargetRoot)) return;

  const copied = [];

  function visit(directory, relativeDirectory = "") {
    if (isInsidePath(path.resolve(directory), resolvedTargetRoot)) return;

    const entries = fs
      .readdirSync(directory, { withFileTypes: true })
      .sort((left, right) => left.name.localeCompare(right.name));

    for (const entry of entries) {
      const relativePath = path.join(relativeDirectory, entry.name);
      const source = path.join(resolvedSourceRoot, relativePath);

      if (isEnvFileName(entry.name)) {
        const target = path.join(resolvedTargetRoot, relativePath);
        if (fs.existsSync(target)) continue;

        fs.mkdirSync(path.dirname(target), { recursive: true });
        fs.cpSync(source, target, {
          recursive: true,
          preserveTimestamps: true,
        });
        copied.push(relativePath);
        continue;
      }

      if (entry.isDirectory() && !shouldSkipEnvSearchDirectory(entry.name)) {
        visit(source, relativePath);
      }
    }
  }

  visit(resolvedSourceRoot);

  if (copied.length > 0) {
    console.error(`wt: copied ${copied.join(", ")}`);
  }
}

function resolveInsideRoot(root, relativePath) {
  const resolvedRoot = path.resolve(root);
  const resolvedPath = path.resolve(resolvedRoot, relativePath);
  const relativeToRoot = path.relative(resolvedRoot, resolvedPath);

  if (relativeToRoot === "" || relativeToRoot.startsWith("..") || path.isAbsolute(relativeToRoot)) {
    die(`unsafe repository path '${relativePath}'`);
  }

  return resolvedPath;
}

function copyUntrackedWorkspaceFiles(sourceRoot, targetRoot) {
  const output = git(["ls-files", "--others", "--exclude-standard", "-z"], {
    cwd: sourceRoot,
  }).stdout;
  const paths = output.split("\0").filter(Boolean);
  let copied = 0;

  for (const relativePath of paths) {
    const source = resolveInsideRoot(sourceRoot, relativePath);
    const target = resolveInsideRoot(targetRoot, relativePath);

    if (!fs.existsSync(source)) continue;
    if (fs.existsSync(target)) {
      die(`refusing to overwrite existing path while copying untracked file '${relativePath}'`);
    }

    fs.mkdirSync(path.dirname(target), { recursive: true });
    fs.cpSync(source, target, {
      recursive: true,
      preserveTimestamps: true,
      verbatimSymlinks: true,
    });
    copied += 1;
  }

  return copied;
}

function copyWorkspaceChanges(sourceRoot, targetRoot) {
  const diff = git(["diff", "--binary", "HEAD"], { cwd: sourceRoot }).stdout;
  const copiedTrackedDiff = diff.trim().length > 0;

  if (copiedTrackedDiff) {
    git(["apply", "--binary", "-"], { cwd: targetRoot, input: diff });
  }

  const copiedUntracked = copyUntrackedWorkspaceFiles(sourceRoot, targetRoot);

  if (copiedTrackedDiff || copiedUntracked > 0) {
    console.error(
      `wt: forked workspace changes (tracked diff: ${copiedTrackedDiff ? "yes" : "no"}, untracked files: ${copiedUntracked})`,
    );
  }

  return { copiedTrackedDiff, copiedUntracked };
}

function commandList(args) {
  if (args.length > 0) die("usage: wt list");

  const entries = worktrees();
  const currentRoot = gitOutput(["rev-parse", "--show-toplevel"], {
    allowFailure: true,
  });
  const labelWidth = Math.max(...entries.map((entry) => labelFor(entry).length));

  for (const entry of entries) {
    const marker = path.resolve(entry.path) === path.resolve(currentRoot) ? "*" : " ";
    const label = labelFor(entry).padEnd(labelWidth);
    const suffix = entry.prunable ? "  (prunable)" : "";
    console.log(`${marker} ${label}  ${entry.path}${suffix}`);
  }
}

function commandPath(args) {
  if (args.length > 1) die("usage: wt path [branch]");

  const entries = worktrees().filter((entry) => !entry.bare);
  const entry = args.length === 0 ? selectWorktree(entries) : findWorktree(args[0], entries);
  console.log(entry.path);
}

function commandNew(args) {
  const { options, rest } = parseOptions(args, { path: true, env: true });
  if (rest.length < 1 || rest.length > 2) {
    die("usage: wt new <branch> [base] [--path <path>] [--env]");
  }

  const [branch, base] = rest;
  const sourceRoot = gitOutput(["rev-parse", "--show-toplevel"]);
  const worktreePath = options.path ?? defaultWorktreePath(branch);
  fs.mkdirSync(path.dirname(worktreePath), { recursive: true });

  const gitArgs = ["worktree", "add", "-b", branch, worktreePath];
  if (base) gitArgs.push(base);

  gitVisible(gitArgs);
  if (options.copyEnv === true) copyEnvFiles(sourceRoot, worktreePath);
  console.error(`wt: created ${worktreePath}`);
  console.log(worktreePath);
}

function commandAdd(args) {
  const { options, rest } = parseOptions(args, { path: true, env: true });
  if (rest.length !== 1) die("usage: wt add <branch> [--path <path>] [--env]");

  const [branch] = rest;
  const sourceRoot = gitOutput(["rev-parse", "--show-toplevel"]);
  const worktreePath = options.path ?? defaultWorktreePath(branch);
  fs.mkdirSync(path.dirname(worktreePath), { recursive: true });

  gitVisible(["worktree", "add", worktreePath, branch]);
  if (options.copyEnv === true) copyEnvFiles(sourceRoot, worktreePath);
  console.error(`wt: added ${worktreePath}`);
  console.log(worktreePath);
}

function commandTmp(args) {
  const { options, rest } = parseOptions(args, { env: true, fork: true });
  if (rest.length > 1) die("usage: wt tmp [name] [--env] [--fork|--no-fork]");

  const [name] = rest;
  const currentRoot = gitOutput(["rev-parse", "--show-toplevel"]);
  const currentSourceBranch = currentBranch() || null;
  const currentHead = gitOutput(["rev-parse", "HEAD"]);
  const parentMetadata = readWorktreeMetadata(currentRoot);
  const shouldInheritSource = !currentSourceBranch && parentMetadata;
  const sourcePath = shouldInheritSource
    ? (parentMetadata.sourcePath ?? currentRoot)
    : currentRoot;
  const sourceBranch = shouldInheritSource
    ? (parentMetadata.sourceBranch ?? null)
    : currentSourceBranch;
  const sourceHead = shouldInheritSource
    ? (parentMetadata.sourceHead ?? currentHead)
    : currentHead;
  const shouldForkWorkspace = options.fork ?? (parentMetadata?.temporary === true);
  const worktreePath = defaultTemporaryWorktreePath(name);

  gitVisible(["worktree", "add", "--detach", worktreePath, "HEAD"]);
  writeWorktreeMetadata(worktreePath, {
    temporary: true,
    name: name ?? null,
    sourcePath,
    sourceBranch,
    sourceHead,
    parentPath: currentRoot,
    parentBranch: currentSourceBranch,
    parentHead: currentHead,
    createdAt: new Date().toISOString(),
  });
  if (shouldForkWorkspace) copyWorkspaceChanges(currentRoot, worktreePath);
  if (options.copyEnv === true) copyEnvFiles(currentRoot, worktreePath);
  console.error(`wt: created temporary ${worktreePath}`);
  console.log(worktreePath);
}

function commandPromote(args) {
  const { rest } = parseOptions(args);
  if (rest.length !== 1) die("usage: wt promote <branch>");

  const [branch] = rest;
  const existingBranch = currentBranch();
  if (existingBranch) die(`already on branch '${existingBranch}'`);
  if (branchExists(branch)) die(`branch '${branch}' already exists`);

  gitVisible(["switch", "-c", branch]);

  const metadata = readWorktreeMetadata();
  if (metadata) {
    writeWorktreeMetadata(process.cwd(), {
      ...metadata,
      promotedBranch: branch,
      promotedAt: new Date().toISOString(),
    });
  }

  console.error(`wt: promoted to ${branch}`);
}

function commandPr(args) {
  const { rest } = parseOptions(args);
  if (rest.length > 1) die("usage: wt pr [base]");
  if (!commandExists("gh")) die("gh is required for wt pr");

  const [requestedBase] = rest;
  const branch = currentBranch();
  if (!branch) die("current worktree is detached; run wt promote <branch> first");

  const currentRoot = gitOutput(["rev-parse", "--show-toplevel"]);
  ensureClean({ path: currentRoot }, "current");

  const metadata = readWorktreeMetadata();
  const base = requestedBase ?? defaultTargetBranch(branch, worktrees(), metadata);
  if (base === branch) die("pull request base and head branch are the same");

  console.error(`wt: pushing ${branch}`);
  gitVisible(["push", "-u", "origin", branch]);

  console.error(`wt: opening PR ${branch} -> ${base}`);
  commandVisible("gh", ["pr", "create", "--base", base, "--head", branch, "--fill"]);
}

function commandRemove(args) {
  const { options, rest } = parseOptions(args, { force: true });
  if (rest.length > 1) die("usage: wt rm [branch] [--force]");

  const info = repoInfo();
  const removable = info.entries.filter(
    (entry) => path.resolve(entry.path) !== path.resolve(info.mainPath) && !entry.bare,
  );
  const entry = rest.length === 0 ? selectWorktree(removable) : findWorktree(rest[0], info.entries);

  if (path.resolve(entry.path) === path.resolve(info.mainPath)) {
    die("refusing to remove the main worktree");
  }

  const gitArgs = ["worktree", "remove"];
  if (options.force) gitArgs.push("--force");
  gitArgs.push(entry.path);

  git(gitArgs, { stdio: "inherit" });
  console.error(`wt: removed ${entry.path}`);
}

function commandPrune(args) {
  git(["worktree", "prune", ...args], { stdio: "inherit" });
}

const [command = "help", ...args] = process.argv.slice(2);

switch (command) {
  case "help":
  case "--help":
  case "-h":
    console.log(HELP.trim());
    break;
  case "ls":
  case "list":
    commandList(args);
    break;
  case "new":
    commandNew(args);
    break;
  case "add":
    commandAdd(args);
    break;
  case "tmp":
  case "temp":
    commandTmp(args);
    break;
  case "promote":
    commandPromote(args);
    break;
  case "pr":
    commandPr(args);
    break;
  case "path":
  case "cd":
    commandPath(args);
    break;
  case "rm":
  case "remove":
    commandRemove(args);
    break;
  case "prune":
    commandPrune(args);
    break;
  default:
    die(`unknown command '${command}'\n\n${HELP.trim()}`);
}
