#!/usr/bin/env bash
set -euo pipefail

DOT="$HOME/github.com/odas0r/dot"

# install custom scripts
mkdir -p "$HOME/.local/bin"
ln -sf "$HOME/github.com/odas0r/dot/scripts" "$HOME/.local/bin/scripts"
ln -sf "$HOME/github.com/odas0r/dot/bashrc" "$HOME/.bashrc"
ln -sf "$HOME/github.com/odas0r/dot/inputrc" "$HOME/.inputrc"
# npm login writes auth tokens to the user config, so keep it private.
mkdir -p "$HOME/.config/npm"
touch "$HOME/.config/npm/npmrc.local"
chmod 700 "$HOME/.config/npm"
chmod 600 "$HOME/.config/npm/npmrc.local"

# Old setup symlinked ~/.npmrc to the tracked dotfile. Remove only that symlink.
if [[ -L "$HOME/.npmrc" && "$(readlink "$HOME/.npmrc")" == "$DOT/npmrc" ]]; then
  rm "$HOME/.npmrc"
fi
ln -sf "$HOME/github.com/odas0r/dot/psqlrc" "$HOME/.psqlrc"
ln -sf "$HOME/github.com/odas0r/dot/sqliterc" "$HOME/.sqliterc"
ln -sf "$HOME/github.com/odas0r/dot/bash" "$HOME/.bash"

# run sub-setup scripts for each tool
for sub in gh git kitty nvim pi skills; do
  if [[ -f "$DOT/$sub/setup" ]]; then
    echo "  → Running $sub/setup..."
    DOT="$DOT" bash "$DOT/$sub/setup"
  fi
done

echo "✨ Setup complete!"
